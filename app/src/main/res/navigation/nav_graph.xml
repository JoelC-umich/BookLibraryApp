<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/LoginPage">

    <fragment
        android:id="@+id/LoginPage"
        android:name="com.example.booklibraryapp.LoginPage"
        android:label="@string/login_page_label"
        tools:layout="@layout/login_page">

        <action
            android:id="@+id/action_LoginPage_to_AdminPage"
            app:destination="@id/AdminPage" />
    </fragment>
    <fragment
        android:id="@+id/AdminPage"
        android:name="com.example.booklibraryapp.AdminPage"
        tools:layout="@layout/admin_page">

        <action
            android:id="@+id/action_AdminPage_to_LoginPage"
            app:destination="@id/LoginPage" />
    </fragment>
</navigation>