<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/frameLayout16"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdminViewRooms" >

    <TextView
        android:id="@+id/textAdminViewRooms"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rooms"
        android:textColor="#8E24AA"
        android:textSize="24sp"
        app:layout_constraintBottom_toTopOf="@+id/searchAdminViewRooms"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ListView
        android:id="@+id/listViewAdminViewRooms"
        android:layout_width="350dp"
        android:layout_height="500dp"
        android:clickable="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/searchAdminViewRooms"
        app:layout_constraintVertical_bias="0.0" />

    <SearchView
        android:id="@+id/searchAdminViewRooms"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:queryHint="Room Search"
        app:layout_constraintBottom_toTopOf="@+id/listViewAdminViewRooms"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textAdminViewRooms" />

</androidx.constraintlayout.widget.ConstraintLayout>