<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/frameLayout8"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UserReserveBookResultsPage" >

    <TextView
        android:id="@+id/textUserReserveResultsMiddleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Book Details"
        android:textColor="#9C27B0"
        android:textSize="24sp"
        app:layout_constraintBottom_toTopOf="@+id/imageBookImageOutput"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnReserveBook"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#0091EA"
        android:text="Reserve"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textBookSummaryOutput" />

    <TextView
        android:id="@+id/textBookNameHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Book Name:"
        android:textColor="#000000"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/textBookAuthorHeader"
        app:layout_constraintEnd_toStartOf="@+id/textBookNameOutput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageBookImageOutput" />

    <TextView
        android:id="@+id/textBookCategoryOutput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textColor="#9C27B0"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/textBookSummaryHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/textBookCategoryHeader"
        app:layout_constraintTop_toBottomOf="@+id/textBookAuthorOutput"
        app:layout_constraintVertical_bias="0.55" />

    <TextView
        android:id="@+id/textBookAuthorHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Book Author:"
        android:textColor="#000000"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/textBookCategoryHeader"
        app:layout_constraintEnd_toStartOf="@+id/textBookAuthorOutput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textBookNameHeader" />

    <TextView
        android:id="@+id/textBookAuthorOutput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Author"
        android:textColor="#9C27B0"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/textBookCategoryOutput"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/textBookAuthorHeader"
        app:layout_constraintTop_toBottomOf="@+id/textBookNameOutput" />

    <TextView
        android:id="@+id/textBookNameOutput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Name"
        android:textColor="#9C27B0"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/textBookAuthorOutput"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/textBookNameHeader"
        app:layout_constraintTop_toBottomOf="@+id/imageBookImageOutput" />

    <TextView
        android:id="@+id/textBookCategoryHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Book Category:"
        android:textColor="#000000"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/textBookSummaryHeader"
        app:layout_constraintEnd_toStartOf="@+id/textBookCategoryOutput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textBookAuthorHeader" />

    <TextView
        android:id="@+id/textBookSummaryHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Summary:"
        android:textColor="#000000"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/textBookSummaryOutput"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textBookCategoryHeader" />

    <TextView
        android:id="@+id/textBookSummaryOutput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Summary"
        android:textColor="#9C27B0"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/btnReserveBook"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textBookSummaryHeader" />

    <ImageView
        android:id="@+id/imageBookImageOutput"
        android:layout_width="202dp"
        android:layout_height="209dp"
        app:layout_constraintBottom_toTopOf="@+id/textBookNameHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textUserReserveResultsMiddleText"
        tools:src="@tools:sample/avatars" />

</androidx.constraintlayout.widget.ConstraintLayout>