<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".AdminPage">

    <TextView
        android:id="@+id/textAdminWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome Librarian!"
        android:textColor="#9C27B0"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.061" />

    <Button
        android:id="@+id/btnAdminViewAccounts"
        android:layout_width="151dp"
        android:layout_height="115dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="488dp"
        android:backgroundTint="#0091EA"
        android:text="View Accounts"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textAdminWelcome"
        app:layout_constraintVertical_bias="0.652" />

    <Button
        android:id="@+id/btnAdminViewBorrowedBooks"
        android:layout_width="151dp"
        android:layout_height="115dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="488dp"
        android:backgroundTint="#0091EA"
        android:text="View Borrowed Books"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textAdminWelcome"
        app:layout_constraintVertical_bias="0.652" />

    <Button
        android:id="@+id/btnAdminViewBookRequests"
        android:layout_width="151dp"
        android:layout_height="115dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="356dp"
        android:backgroundTint="#0091EA"
        android:text="View Book Requests"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAdminViewAccounts"
        app:layout_constraintVertical_bias="1.0" />

    <Button
        android:id="@+id/btnAdminViewRoomReservations"
        android:layout_width="151dp"
        android:layout_height="115dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="208dp"
        android:backgroundTint="#0091EA"
        android:text="View Room Reservations"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAdminViewBookRequests"
        app:layout_constraintVertical_bias="1.0" />

    <Button
        android:id="@+id/btnAdminViewRoomRequests"
        android:layout_width="151dp"
        android:layout_height="115dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="356dp"
        android:backgroundTint="#0091EA"
        android:text="View Room Requests"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAdminViewBorrowedBooks"
        app:layout_constraintVertical_bias="1.0" />
</androidx.constraintlayout.widget.ConstraintLayout>