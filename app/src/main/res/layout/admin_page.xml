<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".AdminPage">

    <TextView
        android:id="@+id/textAdminWelcomeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome Librarian!"
        android:textColor="#9C27B0"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.038" />

    <Button
        android:id="@+id/btnAdminViewAccounts"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="#0091EA"
        android:text="View Accounts"
        app:layout_constraintBottom_toTopOf="@+id/btnAdminViewBorrowedBooks"
        app:layout_constraintEnd_toStartOf="@+id/btnAdminViewCreateAccount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textAdminWelcomeText" />

    <Button
        android:id="@+id/btnAdminViewBookRequests"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="#0091EA"
        android:text="View Book Requests"
        app:layout_constraintBottom_toTopOf="@+id/btnAdminViewRoomRequests"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btnAdminViewBorrowedBooks"
        app:layout_constraintTop_toBottomOf="@+id/btnAdminViewCreateAccount" />

    <Button
        android:id="@+id/btnAdminViewRoomReservations"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="#0091EA"
        android:text="View Room Reservations"
        app:layout_constraintBottom_toTopOf="@+id/btnAdminViewBooksInventory"
        app:layout_constraintEnd_toStartOf="@+id/btnAdminViewRoomRequests"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAdminViewBorrowedBooks" />

    <Button
        android:id="@+id/btnAdminViewBooksInventory"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="#0091EA"
        android:text="View Book Inventory"
        app:layout_constraintBottom_toTopOf="@+id/btnAdminViewRooms"
        app:layout_constraintEnd_toStartOf="@+id/btnAdminCreateBookEntryInventory"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAdminViewRoomReservations" />

    <Button
        android:id="@+id/btnAdminViewRooms"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="#0091EA"
        android:text="View Rooms"
        app:layout_constraintBottom_toTopOf="@+id/btnAdminLogout"
        app:layout_constraintEnd_toStartOf="@+id/btnAdminCreateRoom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAdminViewBooksInventory" />

    <Button
        android:id="@+id/btnAdminCreateRoom"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="#0091EA"
        android:text="Create Room"
        app:layout_constraintBottom_toTopOf="@+id/btnAdminLogout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btnAdminViewRooms"
        app:layout_constraintTop_toBottomOf="@+id/btnAdminCreateBookEntryInventory" />

    <Button
        android:id="@+id/btnAdminViewRoomRequests"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="#0091EA"
        android:text="View Room Requests"
        app:layout_constraintBottom_toTopOf="@+id/btnAdminCreateBookEntryInventory"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btnAdminViewRoomReservations"
        app:layout_constraintTop_toBottomOf="@+id/btnAdminViewBookRequests" />

    <Button
        android:id="@+id/btnAdminCreateBookEntryInventory"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="#0091EA"
        android:text="Create Book in Inventory"
        app:layout_constraintBottom_toTopOf="@+id/btnAdminCreateRoom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btnAdminViewBooksInventory"
        app:layout_constraintTop_toBottomOf="@+id/btnAdminViewRoomRequests" />

    <Button
        android:id="@+id/btnAdminViewCreateAccount"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="#0091EA"
        android:text="Create Account"
        app:layout_constraintBottom_toTopOf="@+id/btnAdminViewBookRequests"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btnAdminViewAccounts"
        app:layout_constraintTop_toBottomOf="@+id/textAdminWelcomeText" />

    <Button
        android:id="@+id/btnAdminViewBorrowedBooks"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:backgroundTint="#0091EA"
        android:text="View Borrowed Books"
        app:layout_constraintBottom_toTopOf="@+id/btnAdminViewRoomReservations"
        app:layout_constraintEnd_toStartOf="@+id/btnAdminViewBookRequests"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAdminViewAccounts" />

    <Button
        android:id="@+id/btnAdminLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#0091EA"
        android:text="Logout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAdminViewRooms" />
</androidx.constraintlayout.widget.ConstraintLayout>