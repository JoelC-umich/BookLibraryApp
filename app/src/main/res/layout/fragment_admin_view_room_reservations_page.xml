<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".AdminViewRoomReservationsPage">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayoutRoomReservations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/adminViewRoomReservationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/room_reservations"
            android:textColor="#9C27B0"
            android:textSize="24sp"
            app:layout_constraintBottom_toTopOf="@+id/adminViewRoomReservationSelectDate"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/adminViewRoomReservationSelectDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select a date"
            android:textColor="#0091EA"
            android:textSize="20sp"
            app:layout_constraintBottom_toTopOf="@+id/calendarViewAdminRoomReservations"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/adminViewRoomReservationText" />

        <CalendarView
            android:id="@+id/calendarViewAdminRoomReservations"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@+id/listViewAdminRoomReservations"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/adminViewRoomReservationSelectDate" />

        <!-- ListView with fixed height or constraints to ensure it's scrollable -->
        <ListView
            android:id="@+id/listViewAdminRoomReservations"
            android:layout_width="350dp"
            android:layout_height="200dp"
            android:nestedScrollingEnabled="true"
            android:scrollbars="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/calendarViewAdminRoomReservations" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
