<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/frameLayout2"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UserViewReservedRoomsPage" >

    <TextView
        android:id="@+id/textUserReserveBook2"
        android:layout_width="1008dp"
        android:layout_height="163dp"
        android:text="Reserved Rooms"
        android:textColor="#9C27B0"
        android:textSize="120sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.061" />

    <ListView
        android:id="@+id/listViewAdminViewBookInventory"
        android:layout_width="1912dp"
        android:layout_height="1989dp"
        android:layout_marginBottom="110dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.447"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spinnerReserveBookCategory" />

    <SearchView
        android:layout_width="1855dp"
        android:layout_height="219dp"
        android:layout_marginStart="179dp"
        android:layout_marginTop="123dp"
        android:layout_marginEnd="122dp"
        android:layout_marginBottom="223dp"
        app:layout_constraintBottom_toTopOf="@+id/listViewAdminViewBookInventory"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textUserReserveBook2" />
</androidx.constraintlayout.widget.ConstraintLayout>